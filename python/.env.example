# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# OpenCode.ai — leave empty to disable
OPENCODE_API_KEY=

# Anthropic — leave empty to disable
ANTHROPIC_API_KEY=

# LLM backend (defaults to local Ollama)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5-coder:7b
LLM_API_KEY=local

# LM Studio — leave both empty to disable
# Set LM_STUDIO_HOST to a remote IP for home lab, or leave as localhost
LM_STUDIO_HOST=
LM_STUDIO_PORT=

# Streamlit server port
STREAMLIT_SERVER_PORT=8501

# Corporate network proxy (optional — only needed for RHT models.corp)
# Set up an SSH SOCKS5 tunnel first: ssh -N -D 1080 user@jumphost
# ALL_PROXY=socks5h://localhost:1080
# SSL_NO_VERIFY=true
